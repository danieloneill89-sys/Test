# Copy this file to ".env" and fill in your real keys:
#     cp .env.example .env
# Then edit .env and paste your keys after the = signs (no quotes needed).
# The .env file is git-ignored, so your keys are never committed.

LOGAINM_API_KEY=your-logainm-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
